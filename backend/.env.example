# Скопируй в .env и подставь реальные значения. .env в .gitignore — в git не попадёт.

# --- Подключение к БД ---
# DATABASE_URL — transaction pooler (порт 6543). Рантайм приложения.
# Render не ходит по IPv6, а прямой connect Supabase только IPv6 → нужен пулер (IPv4).
DATABASE_URL=postgresql://postgres.pgncpphrzktmtnjmmapu:ПАРОЛЬ@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# DATABASE_URL_DIRECT — для Alembic-миграций. Бери SESSION POOLER (порт 5432 на
# pooler-хосте): он IPv4 (direct-хост db.*.supabase.co только IPv6 и не везде резолвится)
# и держит сессию + prepared statements — то, что нужно миграциям.
DATABASE_URL_DIRECT=postgresql://postgres.PROJECT_REF:ПАРОЛЬ@aws-0-РЕГИОН.pooler.supabase.com:5432/postgres

# --- Auth (Supabase) ---
# Project URL. Из него берём JWKS (.well-known/jwks.json) и проверяем ES256-токены.
# Секрет хранить не нужно: проверка асимметричная, публичным ключом.
SUPABASE_URL=https://ТВОЙ_PROJECT_REF.supabase.co

# --- Защита cron-эндпоинта спавна ---
# Любая длинная случайная строка. Её же положим в cron (заголовок X-Cron-Secret).
CRON_SECRET=замени_на_длинную_случайную_строку

# --- CORS ---
# Локально — Vite dev-сервер. На Render заменим на домен Firebase Hosting.
FRONTEND_ORIGIN=http://localhost:5173
