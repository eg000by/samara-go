# Скопируй в .env. VITE_*-переменные попадают в бандл — клади сюда только ПУБЛИЧНОЕ.
# anon-ключ Supabase публичный по дизайну (доступ ограничивает RLS) — это нормально.

VITE_API_URL=https://piter-go-api.onrender.com
VITE_SUPABASE_URL=https://ТВОЙ_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=твой_anon_ключ_из_supabase_settings_api
